  {
    "id": "what-is-hla",
    "number": 1,
    "presenter": "scientist-1",
    "title": "What Is HLA?",
    "shortLabel": "HLA ID",
    "timelineIcon": "icon-welcome",
    "background": "bg-pixel-lab",
    "dialogue": {
      "speaker": "Scientist 1",
      "text": "HLA molecules work like cell ID tags. They help immune cells decide what looks like self and what needs a closer look."
    },
    "infoPopups": [
      {
        "speaker": "scientist-1",
        "title": "HLA Cell ID",
        "text": "HLA stands for human leukocyte antigen. HLA is the human version of the MHC system, encoded in a gene-rich region on chromosome 6.",
        "audio": "/assets/audio/scientist-1/hla-cell-id.mp3",
        "x": 1010,
        "y": 245
      }
    ],
    "cards": [
      {
        "title": "HLA",
        "text": "Human MHC: cell-surface molecules that present peptide clues.",
        "x": 285,
        "y": 175,
        "width": 310,
        "height": 105
      },
      {
        "title": "Chromosome 6",
        "text": "The HLA genes sit together in the MHC region.",
        "x": 650,
        "y": 170,
        "width": 300,
        "height": 100
      },
      {
        "title": "Self vs Non-Self",
        "text": "Immune cells inspect HLA displays before reacting.",
