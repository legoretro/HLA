  {
    "id": "six-allele-teaching-model",
    "number": 4,
    "presenter": "scientist-2",
    "title": "Six-Allele Matching Model",
    "shortLabel": "6 ALLELES",
    "timelineIcon": "icon-match",
    "background": "bg-pixel-lab",
    "dialogue": {
      "speaker": "Scientist 2",
      "text": "For this class example, we will only compare two alleles each at HLA-A, HLA-B, and HLA-C. Real matching can use more loci and higher resolution."
    },
    "infoPopups": [
      {
        "speaker": "scientist-2",
        "title": "Simplified Teaching Model",
        "text": "This 6-allele model is for learning the matching idea. Clinical HLA assessment may include Class II loci, allele-level resolution, antibodies, crossmatch results, and the clinical context.",
        "audio": "/assets/audio/scientist-2/six-allele-model.mp3",
        "x": 1015,
        "y": 230
      }
    ],
    "cards": [
      {
        "title": "SIMPLIFIED TEACHING MODEL",
        "text": "Compare HLA-A, HLA-B, and HLA-C only.",
        "x": 640,
        "y": 132,
        "width": 520,
        "height": 75
      },
      {
        "title": "Recipient",
        "text": "A*02  A*24\nB*07  B*44\nC*07  C*16",
