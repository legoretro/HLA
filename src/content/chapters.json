  {
    "id": "class-i-vs-class-ii",
    "number": 2,
    "presenter": "scientist-1",
    "title": "Class I vs Class II",
    "shortLabel": "I vs II",
    "timelineIcon": "icon-class-i",
    "background": "bg-pixel-lab",
    "dialogue": {
      "speaker": "Scientist 1",
      "text": "Class I and Class II both present peptides, but they do it in different places and talk to different T-cell teams."
    },
    "infoPopups": [
      {
        "speaker": "scientist-1",
        "title": "Class I and Class II",
        "text": "Class I includes HLA-A, HLA-B, and HLA-C on most nucleated cells. Class II includes HLA-DR, HLA-DQ, and HLA-DP on antigen-presenting cells.",
        "audio": "/assets/audio/scientist-1/class-i-class-ii.mp3",
        "x": 1015,
        "y": 235
      }
    ],
    "cards": [
      {
        "title": "Class I",
        "text": "HLA-A, HLA-B, HLA-C\nMost nucleated cells\nPresents inside-cell peptides to CD8 T cells",
        "x": 360,
        "y": 178,
        "width": 385,
        "height": 130
      },
      {
        "title": "Class II",
        "text": "HLA-DR, HLA-DQ, HLA-DP\nAntigen-presenting cells\nPresents outside-source peptides to CD4 T cells",
        "x": 845,
        "y": 178,
        "width": 385,
        "height": 130
      }
    ],
