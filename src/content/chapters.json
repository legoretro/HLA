  {
    "id": "pcr-ssp",
    "number": 6,
    "presenter": "scientist-3",
    "title": "PCR-SSP Finds an Allele",
    "shortLabel": "PCR-SSP",
    "timelineIcon": "icon-pcr",
    "background": "bg-pixel-lab",
    "dialogue": {
      "speaker": "Scientist 3",
      "text": "In PCR-SSP, a primer set is designed for a specific allele. If the primer matches, amplification happens and a gel band appears."
    },
    "infoPopups": [
      {
        "speaker": "scientist-3",
        "title": "PCR-SSP Chain",
        "text": "Primer match -> amplification -> gel band -> HLA allele call. No band means that primer set did not amplify the target under the test conditions.",
        "audio": "/assets/audio/scientist-3/pcr-ssp.mp3",
        "x": 955,
        "y": 235
      },
      {
        "speaker": "scientist-3",
        "title": "Other Methods",
        "text": "SSOP uses labeled probes, Sanger sequencing reads DNA sequence, and NGS can read many HLA regions at high depth. Labs choose methods based on resolution, time, and workflow.",
        "audio": "/assets/audio/scientist-3/other-methods.mp3",
        "x": 1070,
        "y": 310
      }
    ],
    "cards": [
      {
        "title": "1. Primer Match",
        "text": "Allele-specific primer fits the target sequence.",
        "x": 260,
        "y": 175,
        "width": 280,
        "height": 95
      },
      {
        "title": "2. Amplify",
        "text": "PCR copies the target only when the primer works.",
        "x": 525,
        "y": 175,
        "width": 280,
        "height": 95
      },
      {
        "title": "3. Gel Band",
        "text": "A visible band marks successful amplification.",
        "x": 790,
        "y": 175,
        "width": 280,
        "height": 95
      },
      {
        "title": "4. Allele Call",
        "text": "The band pattern supports the HLA allele assignment.",
        "x": 1055,
        "y": 175,
        "width": 280,
        "height": 95
      }
    ],
