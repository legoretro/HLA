  {
    "id": "polymorphism-inheritance",
    "number": 3,
    "presenter": "scientist-2",
    "title": "Alleles and Inheritance",
    "shortLabel": "ALLELES",
    "timelineIcon": "icon-family",
    "background": "bg-pixel-lab",
    "dialogue": {
      "speaker": "Scientist 2",
      "text": "HLA is highly polymorphic, which means many allele versions exist. You inherit linked HLA sets from each parent."
    },
    "infoPopups": [
      {
        "speaker": "scientist-2",
        "title": "Why so many alleles?",
        "text": "HLA diversity helps populations present many different peptide clues. In transplant testing, that same diversity makes matching more specific.",
        "audio": "/assets/audio/scientist-2/polymorphism-inheritance.mp3",
        "x": 1005,
        "y": 235
      }
    ],
    "cards": [
      {
        "title": "Polymorphism",
        "text": "Many HLA allele versions exist at the same gene locus.",
        "x": 310,
        "y": 180,
        "width": 345,
        "height": 105
      },
      {
        "title": "Haplotype",
        "text": "A linked group of HLA alleles inherited together from one parent.",
